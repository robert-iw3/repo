global:
  scrape_interval: 15s
scrape_configs:
- job_name: 'gitea'
  static_configs:
  - targets: ['gitea.dev.io:3000']
- job_name: 'patroni'
  static_configs:
  - targets: ['patroni-gitea.dev.io:8008']
- job_name: 'pgbouncer'
  static_configs:
  - targets: ['pgbouncer.dev.io:6432']
- job_name: 'prometheus'
  static_configs:
  - targets: ['prometheus.dev.io:9090']
- job_name: 'loki'
  static_configs:
  - targets: ['loki.dev.io:3100']