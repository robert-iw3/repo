apiVersion: v1
kind: Service
metadata:
  name: patroni
  namespace: gitea
spec:
  selector:
    app: patroni
  ports:
  - port: 5432
    targetPort: 5432
  - port: 8008
    targetPort: 8008
  clusterIP: None
---
apiVersion: v1
kind: Service
metadata:
  name: pgbouncer
  namespace: gitea
spec:
  selector:
    app: pgbouncer
  ports:
