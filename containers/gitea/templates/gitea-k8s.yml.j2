---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: gitea-ingress
  namespace: gitea
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
{% if use_letsencrypt %}
    traefik.ingress.kubernetes.io/router.tls.certresolver: le
{% else %}
    traefik.ingress.kubernetes.io/router.tls.domains[0].main: {{ gitea_domain }}
{% endif %}
    traefik.ingress.kubernetes.io/router.middlewares: gitea-securityHeaders@kubernetescrd,gitea-modsecurity@kubernetescrd,gitea-rateLimit@kubernetescrd
spec:
  rules:
  - host: {{ gitea_domain }}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: gitea
            port:
              number: 3000
