# Docker secrets store sensitive data (e.g., SIEM tokens, MinIO creds) securely, avoiding plain env vars or files.
# Secrets are encrypted and only accessible to assigned services.
# echo "your-splunk-or-elastic-token" > siem_token.secret
# echo "minioadmin" > minio_user.secret  # Or your custom
# echo "minioadmin" > minio_password.secret

# SIEM Configuration (choose splunk or elastic for SIEM_TYPE)
SIEM_TYPE=elastic
SIEM_URL=http://localhost:9200  # For Elastic: http://your-elastic-host:9200; For Splunk: https://your-splunk-host:8088/services/collector/event
SIEM_TOKEN=your-api-token-or-password
INDEX_NAME=strelka-scans  # For Elastic; ignored for Splunk

# Strelka Host (internal, usually no change needed)
STRELKA_HOST=frontend:8732

# Optional: Suricata Interface (for live traffic monitoring)
SURICATA_INTERFACE=eth0  # Change to your host's network interface if needed (e.g., en0 on macOS, or host.docker.internal on Windows)