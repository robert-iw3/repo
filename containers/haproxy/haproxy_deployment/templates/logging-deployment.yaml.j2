apiVersion: apps/v1
kind: Deployment
metadata:
  name: fluentd
  namespace: default
  labels:
    app: fluentd
spec:
  replicas: 1
  selector:
    matchLabels:
      app: fluentd
  template:
    metadata:
      labels:
        app: fluentd
      annotations:
        pod-security.kubernetes.io/enforce: restricted
    spec:
      containers:
      - name: fluentd
        image: fluent/fluentd:v1.14-1
        ports:
        - containerPort: 24224
          name: fluentd-port
        volumeMounts:
        - name: config
          mountPath: /fluentd/etc
        resources:
          limits:
            cpu: "500m"
            memory: "512Mi"
          requests:
            cpu: "250m"
            memory: "256Mi"
      volumes:
      - name: config
        configMap:
          name: fluentd-config
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: fluentd-config
  namespace: default
data:
  fluentd.conf: |
    <source>
      @type forward
      port 24224
      bind 0.0.0.0
    </source>
    <match haproxy.**>
      @type opensearch
      host {{ opensearch_host | default('opensearch') }}
      port {{ opensearch_port | default(9200) }}
      index_name haproxy-logs
      type_name _doc
      include_timestamp true
    </match>
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: opensearch
  namespace: default
  labels:
    app: opensearch
spec:
  replicas: 1
  selector:
    matchLabels:
      app: opensearch
  template:
    metadata:
      labels:
        app: opensearch
      annotations:
        pod-security.kubernetes.io/enforce: restricted
    spec:
      containers:
      - name: opensearch
        image: opensearchproject/opensearch:2.17.1
        ports:
        - containerPort: 9200
          name: opensearch-port
        env:
        - name: discovery.type
          value: single-node
        - name: OPENSEARCH_JAVA_OPTS
          value: "-Xms512m -Xmx512m"
        volumeMounts:
        - name: opensearch-config
          mountPath: /usr/share/opensearch/config/opensearch.yml
          subPath: opensearch.yml
        resources:
          limits:
            cpu: "1"
            memory: "1Gi"
          requests:
            cpu: "500m"
            memory: "512Mi"
      volumes:
      - name: opensearch-config
        configMap:
          name: opensearch-config
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: opensearch-config
  namespace: default
data:
  opensearch.yml: |
    cluster.name: opensearch-cluster
    network.host: 0.0.0.0
    discovery.type: single-node
    plugins.security.disabled: true
---
apiVersion: v1
kind: Service
metadata:
  name: opensearch
  namespace: default
spec:
  selector:
    app: opensearch
  ports:
  - name: opensearch-port
    port: 9200
    targetPort: 9200
    protocol: TCP
  type: ClusterIP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: opensearch-dashboards
  namespace: default
  labels:
    app: opensearch-dashboards
spec:
  replicas: 1
  selector:
    matchLabels:
      app: opensearch-dashboards
  template:
    metadata:
      labels:
        app: opensearch-dashboards
      annotations:
        pod-security.kubernetes.io/enforce: restricted
    spec:
      containers:
      - name: opensearch-dashboards
        image: opensearchproject/opensearch-dashboards:2.17.1
        ports:
        - containerPort: 5601
          name: dashboards-port
        env:
        - name: OPENSEARCH_HOSTS
          value: http://opensearch:9200
        resources:
          limits:
            cpu: "500m"
            memory: "512Mi"
          requests:
            cpu: "250m"
            memory: "256Mi"
---
apiVersion: v1
kind: Service
metadata:
  name: opensearch-dashboards
  namespace: default
spec:
  selector:
    app: opensearch-dashboards
  ports:
  - name: dashboards-port
    port: 5601
    targetPort: 5601
    protocol: TCP
  type: ClusterIP