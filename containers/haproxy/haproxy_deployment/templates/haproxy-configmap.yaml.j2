apiVersion: v1
kind: ConfigMap
metadata:
  name: haproxy-config
  namespace: default
data:
  haproxy.cfg: |
    global
      log stdout format raw daemon {{ log_level | default('info') }}
      pidfile /run/haproxy.pid
      maxconn 4000
      server-state-file /var/lib/haproxy/server-state

    defaults
      mode http
      log global
      option httplog
      option dontlognull
      option http-server-close
      option redispatch
      retries 3
      timeout http-request 10s
      timeout queue 1m
      timeout connect 10s
      timeout client 10m
      timeout server 10m
      timeout http-keep-alive 10s
      timeout check 10s
      maxconn 3000
      load-server-state-from-file global
      errorfile 400 /usr/local/etc/haproxy/errors/400.http
      errorfile 403 /usr/local/etc/haproxy/errors/403.http
      errorfile 408 /usr/local/etc/haproxy/errors/408.http
      errorfile 500 /usr/local/etc/haproxy/errors/500.http
      errorfile 502 /usr/local/etc/haproxy/errors/502.http
      errorfile 503 /usr/local/etc/haproxy/errors/503.http
      errorfile 504 /usr/local/etc/haproxy/errors/504.http

    {% for service in services | default([{'name': 'default', 'backend': 'localhost', 'port': 8080}]) %}
    backend {{ service.name }}
      server {{ service.name }} {{ service.backend }}:{{ service.port }}
      {% if service.health_check %}
      option httpchk {{ service.health_check.method }} {{ service.health_check.path }}
      {% endif %}

    frontend {{ service.name }}-frontend
      bind :::{{ service.port }} v4v6
      default_backend {{ service.name }}
    {% endfor %}