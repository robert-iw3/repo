# Database configuration
POSTGRES_DB=defguard
POSTGRES_USER=defguard
POSTGRES_PASSWORD=secure_password_here
PGDATA=/var/lib/postgresql/data/pgdata

# Defguard core configuration
DEFGUARD_DEFAULT_ADMIN_PASSWORD=secure_admin_password
DEFGUARD_COOKIE_INSECURE=false
DEFGUARD_COOKIE_DOMAIN=example.com
DEFGUARD_LOG_LEVEL=info
DEFGUARD_SECRET_KEY=generate_a_strong_key_here
DEFGUARD_AUTH_SECRET=auth_secret_here
DEFGUARD_GATEWAY_SECRET=gateway_secret_here
DEFGUARD_YUBIBRIDGE_SECRET=yubibridge_secret_here
DEFGUARD_DB_HOST=db
DEFGUARD_DB_PORT=5432
DEFGUARD_URL=https://example.com:8000
RUST_BACKTRACE=0
DEFGUARD_TOKEN=generate_a_jwt_token_here
DEFGUARD_STATS_PERIOD=60
RUST_LOG=info

# TLS certificates (paths inside container)
DEFGUARD_TLS_CERT=/certs/tls.crt
DEFGUARD_TLS_KEY=/certs/tls.key