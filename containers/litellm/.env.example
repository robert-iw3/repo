# API Keys (replace with actual keys; store securely in a secrets manager for production)
ANTHROPIC_API_KEY=
GOOGLE_CREDENTIAL_PATH=./.google_credentials.json
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_VERTEX_PROJECT=
GROQ_API_KEY=
OPENAI_API_KEY=

# App configuration
FQDN=example.com # Set to your domain (e.g., litellm.example.com)
POSTGRES_DB_URL=postgresql://litellm:POSTGRES_PASSWORD@postgres:5432/litellm
POSTGRES_PASSWORD= # Generate a strong password
POSTGRES_USER=litellm
UI_PASSWORD= # Set a secure password for UI access
UI_USERNAME=litellm
PROMETHEUS_PORT=9090 # Port for Prometheus monitoring