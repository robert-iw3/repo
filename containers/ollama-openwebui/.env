# Open WebUI settings (https://docs.openwebui.com/getting-started/advanced-topics/env-configuration)
WEBUI_AUTH=True # You must set a WEBUI_SECRET_KEY to activate auth in Open WebUI
WEBUI_SECRET_KEY="set_webui_secret_key" # `openssl rand -hex 32`
WEBUI_BYPASS_MODEL_ACL=False # Bypass access control (if you're not using roles - use this only in a trusted environment
WEBUI_SESSION_COOKIE_SECURE=True
DEFAULT_LOCALE="en"

# Authentik OAUTH vars
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# OPENID_PROVIDER_URL is in the form of
# https://[authentik.domain]/application/o/[application]/.well-known/openid-configuration.
# Setup proxy, DNS record to authentik web server
# Ex: https://localhost:9443/application/o/open-webui/.well-known/openid-configuration
OPENID_PROVIDER_URL=
OAUTH_PROVIDER_NAME=Authentik
ENABLE_OAUTH_SIGNUP=true
OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true
OAUTH_SCOPES="openid email profile"
OPENID_REDIRECT_URI=

## RAG - Reality Augmented Generation
#ENABLE_RAG_WEB_SEARCH=True
#RAG_WEB_SEARCH_RESULT_COUNT=5
#PDF_EXTRACT_IMAGES=True

# System Configuration
HOSTNAME="open-webui.ai"
TRAEFIK_HOSTNAME="open-webui.ai"
TIMEZONE=America/Chicago
# SearXNG settings
## Generate a new secret key for production
#SEARXNG_SECRET="set_searxng_secret_key" # `openssl rand -hex 32`
#SEARXNG_LIMITER=False
#SEARXNG_PUBLIC_INSTANCE=False

# Traefik Variables
TRAEFIK_IMAGE_TAG=traefik:3.2
TRAEFIK_LOG_LEVEL=WARN
# The email address used by Let's Encrypt for renewal notices
TRAEFIK_ACME_EMAIL=admin@example.com
# The hostname used to access the Traefik dashboard and to configure domain-specific rules
TRAEFIK_HOSTNAME=traefik.ollama.ai
# Basic Authentication for Traefik Dashboard
# Username: traefikadmin
# Passwords must be encoded using MD5, SHA1, or BCrypt https://hostingcanada.org/htpasswd-generator/
TRAEFIK_BASIC_AUTH=traefikadmin: