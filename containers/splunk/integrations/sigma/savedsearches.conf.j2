{% for rule in detection_rules %}
# Generated with Sigma2SplunkAlert
[{{ rule.title }}]
action.email = {{ config.alert_action.email.enabled | default(1) }}
action.email.subject.alert = Splunk Alert: $name$
action.email.to = {{ config.alert_action.email.to | default('ticketing@example.com') }}
action.email.message.alert = Splunk Alert $name$ triggered \
List of interesting fields: \
{% for field in rule.fields %}
{{ field }}: $result.{{ field }}$ \
{% endfor %}
MITRE Techniques: {{ rule.mitre_techniques | join(', ') }} \
MITRE Tactics: {{ rule.mitre_tactics | join(', ') }}
title: {{ rule.title }}
description: {{ rule.description }}
tags: {{ rule.tags | join(', ') }}
level: {{ rule.level }}
action.email.useNSSubject = 1
alert.severity = {{ config.alert_severity | default(1) }}
alert.suppress = 0
alert.track = 1
alert.expires = 24h
counttype = number of events
cron_schedule = {{ config.cron_schedule | default('*/10 * * * *') }}
dispatch.earliest_time = {{ config.earliest_time | default('-10m') }}
dispatch.latest_time = {{ config.latest_time | default('now') }}
enableSched = 1
quantity = 0
relation = greater than
request.ui_dispatch_app = {{ config.app | default('sigma_hunting_app') }}
request.ui_dispatch_view = search
search = {{ rule.splunk_search }}
{% if rule.datamodel %}
# CIM Data Model
action.datamodel = 1
action.datamodel.name = {{ rule.datamodel }}
{% endif %}
{% endfor %}