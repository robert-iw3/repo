{{ podman_systemd_description | comment }}

[Unit]
Description={{ podman_systemd_description }}
Documentation=man:podman-generate-systemd(1)
Wants=network-online.target
After=network-online.target
RequiresMountsFor=%t/containers

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=on-failure
TimeoutStopSec=70
KillMode=mixed
KillSignal=SIGTERM
LimitNOFILE=65536
LimitMEMLOCK=infinity
CPUWeight=100
ExecStartPre=/bin/rm -f %t/%n-pid %t/%n-cid
ExecStart=/usr/bin/podman run \
  --cidfile=%t/%n-cid \
  --cgroups=no-conmon \
  --rm \
  --replace \
  --name {{ podman_systemd_name }} \
  --log-driver=journald \
  --network {{ podman_systemd_network | default('host') }} \
{% for port in podman_systemd_ports %}
  --publish {{ port }} \
{% endfor %}
{% for volume in podman_systemd_volumes %}
  --volume {{ volume }} \
{% endfor %}
{% for var, value in podman_systemd_environment.items() %}
  --env {{ var }}={{ value }} \
{% endfor %}
  --security-opt no-new-privileges=true \
  {{ podman_systemd_image }}
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n-cid -t 10
ExecStopPost=/usr/bin/podman rm --ignore -f --cidfile=%t/%n-cid
Type=notify
NotifyAccess=all
PIDFile=%t/%n-pid
SyslogIdentifier={{ podman_systemd_name }}

[Install]
WantedBy=multi-user.target