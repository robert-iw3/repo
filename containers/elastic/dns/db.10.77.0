$TTL    604800
@       IN      SOA     dns.containers.local. mail.containers.local. (
                              2         ; Serial
                         604800         ; Refresh
                          86400         ; Retry
                        2419200         ; Expire
                         604800 )       ; Negative Cache TTL
;
; name servers - NS records
        IN      NS      dns.containers.local.

;
; PTR Records
201     IN      PTR     dns.containers.local.               ; 10.77.0.2
202     IN      PTR     elastic.containers.local.           ; 10.77.0.3
220     IN      PTR     kibana.containers.local.            ; 10.77.0.4
221     IN      PTR     fleet.containers.local.             ; 10.77.0.5
230     IN      PTR     apm-server.containers.local.        ; 10.77.0.6
231     IN      PTR     enterprise-search.containers.local. ; 10.77.0.7
240     IN      PTR     authentik.containers.local          ; 10.77.0.8