$ORIGIN containers.local.
@	3600 IN	SOA dns.containers.local. mail.containers.local. (
				2017042745 ; serial
				7200       ; refresh (2 hours)
				3600       ; retry (1 hour)
				1209600    ; expire (2 weeks)
				3600       ; minimum (1 hour)
				)

	3600 IN NS a.iana-servers.net.
	3600 IN NS b.iana-servers.net.

dns       IN  A   10.77.0.2
elastic    IN  A   10.77.0.3
kibana    IN  A   10.77.0.4
fleet    IN  A   10.77.0.5
apm-server    IN  A   10.77.0.6
enterprise-search    IN  A   10.77.0.7
authentik    IN  A   10.77.0.8