# === ELASTIC VERSION ===
ELASTIC_VERSION=9.2.0

# === SECURITY PASSWORDS (AUTO-GENERATED) ===
ELASTIC_PASSWORD=replace_with_generated_value
KIBANA_SYSTEM_PASSWORD=replace_with_generated_value
LOGSTASH_INTERNAL_PASSWORD=replace_with_generated_value
METRICBEAT_INTERNAL_PASSWORD=replace_with_generated_value
FILEBEAT_INTERNAL_PASSWORD=replace_with_generated_value
HEARTBEAT_INTERNAL_PASSWORD=replace_with_generated_value
MONITORING_INTERNAL_PASSWORD=replace_with_generated_value
BEATS_SYSTEM_PASSWORD=replace_with_generated_value
ENT_SEARCH_DEFAULT_PASSWORD=replace_with_generated_value
APM_SERVER_TOKEN=replace_with_generated_value

# === CONTAINER RUNTIME ===
CONTAINER_RUNTIME=podman  # or docker

# === vSPHERE CONFIGURATION ===
VCENTER_HOST=vcenter.example.com
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=your_vcenter_password
DATACENTER=Datacenter
CLUSTER=Cluster
DATASTORE=datastore1
TEMPLATE=ubuntu-template

# === NETWORK & SECURITY ===
SUBNET=192.168.1.0/24
GATEWAY=192.168.1.1
NAMESERVERS=8.8.8.8,1.1.1.1

# === CLOUD-INIT USER CONFIG ===
SSH_USER=elastic
SSH_KEY=~/.ssh/id_rsa
CLOUDINIT_TIMEZONE=UTC
CLOUDINIT_PACKAGES=vim,curl,git,ca-certificates,gnupg,openssh-server

# === DYNAMIC FROM ORCHESTRATION (DO NOT EDIT) ===
# These are injected by orchestrate.py
VM_SPECS={}
ES_HOSTNAMES=
ES_IPS=
KIBANA_HOSTNAMES=
KIBANA_IPS=
FLEET_HOSTNAMES=
FLEET_IPS=