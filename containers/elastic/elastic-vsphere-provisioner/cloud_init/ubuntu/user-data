#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  timezone: {{ timezone }}
  identity:
    hostname: {{ hostname }}
    username: {{ ssh_user }}
    password: "$6$rounds=4096${{ ssh_password }}"
  ssh:
    install-server: yes
    allow-pw: true
  network:
    version: 2
    ethernets:
      ens192:
        dhcp4: no
        addresses: [{{ ip }}/24]
        gateway4: {{ gateway }}
        nameservers:
          addresses: [{{ nameservers }}]
  storage:
    layout:
      name: lvm
  packages:
    - {{ packages }}
  late-commands:
    - curtin in-target --target=/target -- apt update
    - curtin in-target --target=/target -- apt upgrade -y
    - curtin in-target --target=/target -- apt install -y podman docker.io ufw
    - curtin in-target --target=/target -- usermod -aG docker {{ ssh_user }}
    - curtin in-target --target=/target -- usermod -aG podman {{ ssh_user }}
    - curtin in-target --target=/target -- systemctl enable podman.socket
    - curtin in-target --target=/target -- ufw default deny incoming
    - curtin in-target --target=/target -- ufw default allow outgoing
    - curtin in-target --target=/target -- ufw allow from {{ allowed_subnet }} to any port 22 proto tcp
    - curtin in-target --target=/target -- ufw allow from {{ allowed_subnet }} to any port 9200 proto tcp
    - curtin in-target --target=/target -- ufw allow from {{ allowed_subnet }} to any port 9300 proto tcp
    - curtin in-target --target=/target -- ufw allow from {{ allowed_subnet }} to any port 5601 proto tcp
    - curtin in-target --target=/target -- ufw allow from {{ allowed_subnet }} to any port 8220 proto tcp
    - curtin in-target --target=/target -- ufw --force enable