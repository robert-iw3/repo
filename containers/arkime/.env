# environment file for docker-compose

# the OpenSearch version
OS_VERSION=3

# the names of the OpenSearch nodes
OS_NODE1=os01
# OS_NODE2=os02

# mem and heap size
OS_JAVA_MEM=1g

# the port were the Arkime instance can be reached
ARKIME_PORT=8005

# the path were your PCAP files are stored
# or should be stored if you want to use arkime-capture
PCAP_DIR=./pcaps

# suricata eve.json monitoring
EVE_DIR=/var/log/suricata
