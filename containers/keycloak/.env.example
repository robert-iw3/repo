# Keycloak and PostgreSQL credentials
POSTGRESQL_USERNAME=keycloak
POSTGRESQL_PASSWORD=secure_password
POSTGRESQL_DATABASE=keycloak
POSTGRESQL_REPLICATION_USER=repl_user
POSTGRESQL_REPLICATION_PASSWORD=secure_repl_password
KEYCLOAK_USER=admin
KEYCLOAK_PASSWORD=secure_admin_password
DB_VENDOR=postgres
DB_ADDR=postgres
JGROUPS_DISCOVERY_PROTOCOL=dns.DNS_PING
JGROUPS_DISCOVERY_PROPERTIES=dns_query=keycloak.keycloak.svc.cluster.local
PROXY_ADDRESS_FORWARDING=true
KEYCLOAK_LOGLEVEL=INFO
TRAEFIK_AUTH_HASHED_PASSWORD=$6$rounds=60000$...
LETSENCRYPT_EMAIL=your.email@example.com