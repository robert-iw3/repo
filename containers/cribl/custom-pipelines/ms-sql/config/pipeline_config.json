{
  "id": "{{pipeline_id}}",
  "description": "Optimized pipeline for MS SQL data with early filtering, performance tracking, and scalable aggregation.",
  "conf": {
    "asyncTimeout": 30000,
    "groups": [
      {
        "id": "prep_group",
        "description": "Initial parsing and enrichment; optimized with early drop for efficiency. (Split point for pre-processing if needed.)",
        "functions": [
          {
            "id": "early_filter",
            "type": "eval",
            "conf": {
              "keep": "category != null"
            },
            "description": "Early filter to drop low-value events before heavy processing"
          },
          {
            "id": "start_timer",
            "type": "eval",
            "conf": {
              "assignments": ["__start_time = Date.now()"]
            },
            "description": "Start performance timer"
          },
          {
            "id": "parse_sql_data",
            "type": "parse",
            "conf": {
              "parser": "json_auto",
              "onError": "drop"
            },
            "description": "Parse SQL rows; drop malformed"
          },
          {
            "id": "validate_dynamic",
            "type": "eval",
            "conf": {
              "keep": "(id !== undefined && typeof(id) === 'number') || (category !== undefined && typeof(category) === 'string') || (__error = true, false)"
            },
            "description": "Dynamic validation"
          },
          {
            "id": "rename_and_mask",
            "type": "js",
            "conf": {
              "function": "function process(event) { if (event.data) { event.event_data = event.data; delete event.data; } Object.keys(event).forEach(key => { if (key.startsWith('sensitive_')) { event[key] = '***MASKED***'; } }); return event; }"
            },
            "description": "Combined rename and mask for fewer functions"
          },
          {
            "id": "enrich_eval",
            "type": "eval",
            "conf": {
              "assignments": [
                "_time = Date.now()",
                "source = '{{source_tag}}'",
                "host = C.INTERNAL.host"
              ]
            },
            "description": "Enrich with metadata"
          }
        ]
      },
      {
        "id": "process_group",
        "description": "Aggregation and volume control; limited groups for scalability. (Split point for post-processing if needed.)",
        "functions": [
          {
            "id": "aggregate_summary",
            "type": "aggregate",
            "conf": {
              "groupBy": ["category"],
              "aggregations": ["count() as event_count", "avg(value) as avg_value"],
              "interval": "{{aggregate_interval}}",
              "maxGroups": 1000
            },
            "description": "Aggregate with group limit"
          },
          {
            "id": "suppress_duplicates",
            "type": "suppress",
            "conf": {
              "fields": ["id"],
              "maxEventsInMemory": 10000,
              "maxKBytesInMemory": 1024
            },
            "description": "Suppress duplicates"
          },
          {
            "id": "limit_batches",
            "type": "limit",
            "conf": {
              "maxEvents": {{limit_max_events}},
              "onExceed": "drop"
            },
            "description": "Limit for large rows"
          },
          {
            "id": "sample_data",
            "type": "sample",
            "conf": {
              "rate": {{sample_rate}}
            },
            "description": "Sample for high-volume"
          }
        ]
      },
      {
        "id": "output_group",
        "description": "Error handling, routing, and metrics export",
        "functions": [
          {
            "id": "end_timer",
            "type": "eval",
            "conf": {
              "assignments": ["__processing_time = Date.now() - __start_time"]
            },
            "description": "Calculate processing time"
          },
          {
            "id": "error_route",
            "type": "routes",
            "conf": {
              "routes": [
                {
                  "filter": "__error == true",
                  "output": "{{error_output}}",
                  "description": "Route errors"
                },
                {
                  "filter": "true",
                  "output": "{{main_output}}",
                  "description": "Main route"
                }
              ]
            },
            "description": "Route with error handling"
          },
          {
            "id": "metrics_export",
            "type": "metrics",
            "conf": {
              "metrics": ["event_count", "__processing_time"],
              "output": "{{metrics_destination}}"
            },
            "description": "Export metrics for monitoring"
          }
        ]
      }
    ]
  }
}