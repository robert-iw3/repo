apiVersion: v1
kind: ConfigMap
metadata:
  name: genai-config
data:
  NEO4J_URI: "{{ NEO4J_URI | default('neo4j://database:7687') }}"
  NEO4J_USERNAME: "{{ NEO4J_USERNAME | default('neo4j') }}"
  NEO4J_DATABASE: "{{ NEO4J_DATABASE | default('neo4j') }}"
  OLLAMA_BASE_URL: "{{ OLLAMA_BASE_URL | default('http://llm:11434') }}"
  LLM: "{{ LLM | default('llama3.2:3b') }}"
  EMBEDDING_MODEL: "{{ EMBEDDING_MODEL | default('openai') }}"
  LANGCHAIN_TRACING_V2: "{{ LANGCHAIN_TRACING_V2 | default('false') }}"
  LANGCHAIN_ENDPOINT: "{{ LANGCHAIN_ENDPOINT | default('https://api.smith.langchain.com') }}"
  LANGCHAIN_PROJECT: "{{ LANGCHAIN_PROJECT | default('neo4j-rag') }}"
  nginx.conf: |
    server {
        listen 8505;
        server_name localhost;
        root /usr/share/nginx/html;
        index index.html;
        location / {
            try_files $uri $uri/ /index.html;
        }
    }