  - protocol: TCP
    port: 8504
    targetPort: 8504
  type: LoadBalancer
---
# Front-end Service
apiVersion: v1
kind: Service
metadata:
  name: front-end
spec:
  selector:
    app: front-end
  ports:
  - protocol: TCP
    port: 8505
    targetPort: 8505
  type: LoadBalancer