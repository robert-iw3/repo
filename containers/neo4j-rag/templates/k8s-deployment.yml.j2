# Ollama LLM Deployment (with multi-tenant annotations)
apiVersion: apps/v1
kind: Deployment
metadata:
  name: llm
spec:
  replicas: 1
  selector:
    matchLabels:
      app: llm
  template:
    metadata:
      labels:
        app: llm
      annotations:  # Prometheus monitoring
        prometheus.io/scrape: "true"
        prometheus.io/port: "11434"
    spec:
      containers:
      - name: llm
        image: {{ image_registry }}/neo4j-genai-llm:latest  # Built from ollama/ollama:latest or custom
        ports:
        - containerPort: 11434
        resources:
          limits:
            cpu: "2"
            memory: 8Gi
          requests:
            cpu: "1"
            memory: 4Gi
        volumeMounts:
        - mountPath: /root/.ollama
          name: ollama-storage
        {% if gpu_enabled %}
        nodeSelector:
          nvidia.com/gpu: "true"
        {% endif %}
        readinessProbe:
          httpGet:
            path: /api/tags
            port: 11434
          initialDelaySeconds: 30
          periodSeconds: 10
      volumes:
      - name: ollama-storage
        persistentVolumeClaim:
          claimName: ollama-pvc
---
# Neo4j Database Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: database
spec:
  replicas: 1
  selector:
    matchLabels:
      app: database
  template:
    metadata:
      labels:
        app: database
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "7474"
    spec:
      containers:
      - name: database
        image: {{ neo4j_image | default('neo4j:5.27.1') }}
        ports:
        - containerPort: 7474
        - containerPort: 7687
        env:
        - name: NEO4J_AUTH
          valueFrom:
            secretKeyRef:
              name: neo4j-secret
              key: auth
        - name: NEO4J_PLUGINS
          value: '["apoc"]'
        - name: NEO4J_db_tx__log_rotation_retention__policy
          value: "false"
        - name: NEO4J_dbms_security_procedures_unrestricted
          value: "apoc.*"
        readinessProbe:
          httpGet:
            path: /
            port: 7474
          initialDelaySeconds: 60
          periodSeconds: 10
        resources:
          limits:
            cpu: "2"
            memory: 4Gi
          requests:
            cpu: "1"
            memory: 2Gi
        volumeMounts:
        - mountPath: /data
          name: neo4j-storage
      volumes:
      - name: neo4j-storage
        persistentVolumeClaim:
          claimName: neo4j-pvc
---
# Bot Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: bot
spec:
  replicas: {{ replicas | default(1) }}
  selector:
    matchLabels:
      app: bot
  template:
    metadata:
      labels:
        app: bot
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8501"
    spec:
      serviceAccountName: genai-sa  # RBAC
      initContainers:
      - name: wait-database
        image: busybox:1.28
        command: ['sh', '-c', 'until nc -z database 7687; do echo waiting for database; sleep 2; done;']
      containers:
      - name: bot
        image: {{ image_registry }}/neo4j-genai-bot:latest
        ports:
        - containerPort: 8501
        envFrom:
        - configMapRef:
            name: genai-config
        - secretRef:
            name: api-secrets
        volumeMounts:
        - mountPath: /app/embedding_model
          name: embedding-storage
        readinessProbe:
          httpGet:
            path: /_stcore/health
            port: 8501
          initialDelaySeconds: 30
          periodSeconds: 10
        resources:
          limits:
            cpu: "1"
            memory: 2Gi
          requests:
            cpu: "0.5"
            memory: 1Gi
      volumes:
      - name: embedding-storage
        persistentVolumeClaim:
          claimName: embedding-pvc
---
