---
# Front-end Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: front-end
spec:
  replicas: {{ replicas | default(1) }}
  selector:
    matchLabels:
      app: front-end
  template:
    metadata:
      labels:
        app: front-end
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8505"
    spec:
      serviceAccountName: genai-sa
      containers:
      - name: front-end
        image: {{ image_registry }}/neo4j-genai-front-end:latest
        ports:
        - containerPort: 8505
        volumeMounts:
        - name: nginx-config
          mountPath: /etc/nginx/conf.d/default.conf
          subPath: default.conf
        readinessProbe:
          httpGet:
            path: /
            port: 8505
          initialDelaySeconds: 10
          periodSeconds: 5
        resources:
          limits:
            cpu: "0.5"
            memory: 512Mi
          requests:
            cpu: "0.25"
            memory: 256Mi
      volumes:
      - name: nginx-config
        configMap:
          name: genai-config
          items:
          - key: nginx.conf
            path: default.conf
---
# Pull-model as Job
apiVersion: batch/v1
kind: Job
metadata:
  name: pull-model
spec:
  template:
    spec:
      serviceAccountName: genai-sa
      containers:
      - name: pull-model
        image: {{ image_registry }}/neo4j-genai-pull-model:latest
        env:
        - name: OLLAMA_BASE_URL
          value: "http://llm:11434"
        - name: LLM
          valueFrom:
            configMapKeyRef:
              name: genai-config
              key: LLM
      restartPolicy: Never
  backoffLimit: 1
---
# PVCs (Persistent Volumes)
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: neo4j-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 10Gi
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: ollama-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 50Gi  # For models
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: embedding-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 5Gi
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: images-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi