apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: genai-ingress
  annotations:
    cert-manager.io/cluster-issuer: "letsencrypt-prod"  # For HTTPS certs
    nginx.ingress.kubernetes.io/rewrite-target: /
spec:
  tls:
  - hosts:
    - your-domain.com
    secretName: genai-tls
  rules:
  - host: your-domain.com
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: front-end
            port:
              number: 8505
      - path: /api
        pathType: Prefix
        backend:
          service:
            name: api
            port:
              number: 8504
      - path: /neo4j
        pathType: Prefix
        backend:
          service:
            name: database
            port:
              number: 7474