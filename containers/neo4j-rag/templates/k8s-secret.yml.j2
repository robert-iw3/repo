apiVersion: v1
kind: Secret
metadata:
  name: neo4j-secret
type: Opaque
data:
  auth: {{ NEO4J_AUTH | b64encode }}  # e.g., neo4j:password base64
---
apiVersion: v1
kind: Secret
metadata:
  name: api-secrets
type: Opaque
data:
  OPENAI_API_KEY: {{ OPENAI_API_KEY | b64encode | default('') }}
  AWS_ACCESS_KEY_ID: {{ AWS_ACCESS_KEY_ID | b64encode | default('') }}
  AWS_SECRET_ACCESS_KEY: {{ AWS_SECRET_ACCESS_KEY | b64encode | default('') }}
  GOOGLE_API_KEY: {{ GOOGLE_API_KEY | b64encode | default('') }}
  NEO4J_PASSWORD: {{ NEO4J_PASSWORD | b64encode }}